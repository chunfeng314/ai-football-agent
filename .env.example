# ===== AI足球经理Agent 环境变量模板 =====
# 复制此文件为 backend/.env 并填入真实值

# LLM 选择: deepseek 或 claude
LLM_PROVIDER=deepseek

# DeepSeek API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# Claude API Key（备选）
ANTHROPIC_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# API-Football Key
APIFOOTBALL_KEY=your-apifootball-key-here

# Redis 配置（Docker 部署时自动设置，本地不用改）
REDIS_HOST=redis
REDIS_PORT=6379

# 缓存 TTL（秒）
CACHE_TTL=3600

# 当前赛季
CURRENT_SEASON=2024
